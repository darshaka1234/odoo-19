<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <!-- Floor Plan Financing Category -->
        <record id="module_category_floor_plan" model="ir.module.category">
            <field name="name">Floor Plan Financing</field>
            <field name="description">Manage floor plan financing operations</field>
            <field name="sequence">10</field>
        </record>
        
        <!-- Platform Admin Group -->
        <record id="group_floor_plan_admin" model="res.groups">
            <field name="name">Platform Admin</field>
            <field name="category_id" ref="module_category_floor_plan"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Full access to floor plan financing module including configuration and all operations</field>
        </record>
        
        <!-- Finance Manager Group -->
        <record id="group_floor_plan_manager" model="res.groups">
            <field name="name">Finance Manager</field>
            <field name="category_id" ref="module_category_floor_plan"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can view and manage agreements, approve funding, process payments</field>
        </record>
        
    </data>
</odoo>
