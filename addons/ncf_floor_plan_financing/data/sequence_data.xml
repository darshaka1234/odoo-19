<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Floor Plan Agreement Sequence -->
        <record id="seq_floor_plan_agreement" model="ir.sequence">
            <field name="name">Floor Plan Agreement Sequence</field>
            <field name="code">floor.plan.agreement</field>
            <field name="prefix">FPA/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
        
        <!-- Floor Plan Transaction Sequence -->
        <record id="seq_floor_plan_transaction" model="ir.sequence">
            <field name="name">Floor Plan Transaction Sequence</field>
            <field name="code">floor.plan.transaction</field>
            <field name="prefix">FPT/%(year)s/</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
        
    </data>
</odoo>
