<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Cron Job: Calculate Daily Interest -->
        <record id="ir_cron_calculate_floor_plan_interest" model="ir.cron">
            <field name="name">Floor Plan: Calculate Daily Interest</field>
            <field name="model_id" ref="model_floor_plan_agreement_line"/>
            <field name="state">code</field>
            <field name="code">model._cron_calculate_all_interest()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="priority">5</field>
        </record>
        
    </data>
</odoo>
