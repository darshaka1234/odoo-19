<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="snippets" inherit_id="website.snippets" name="Product Theme - Snippets">
        <xpath expr="//snippets[@id='snippet_groups']/*[1]" position="before">
            <t snippet-group="product_theme" t-snippet="website.s_snippet_group" string="Product Theme"
               t-thumbnail="/website_airproof/static/src/img/wbuilder/s_airproof_group_thumbnail.svg"/>
        </xpath>

        <xpath expr="//snippets[@id='snippet_structure']/*[1]" position="before">
            <t t-snippet="theme_product_view.product_view" string="Custom snippet" group="product_theme">
                <keywords>Snippet</keywords>
            </t>
        </xpath>
    </template>
</odoo>